# --- Core ---
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Railway PostgreSQL plugin provides this) ---
DATABASE_URL=postgresql://user:password@localhost:5432/aiwa?schema=public

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- WhatsApp / Baileys ---
# Directory where encrypted Baileys auth state is persisted.
# On Railway, point this to a mounted Volume so the session survives restarts.
WA_SESSION_PATH=./.sessions
# Key used to encrypt the auth state at rest. MUST be set to a long random value in production.
SESSION_ENCRYPTION_KEY=please-change-this-to-a-long-random-secret

# --- CORS: the public URL of the web app (use * for local dev) ---
CORS_ORIGIN=*

# Default language inbound messages are translated into (ISO code or language name)
DEFAULT_TRANSLATE_TO=en
